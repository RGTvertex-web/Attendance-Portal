# ─────────────────────────────────────────────────────────────────────────────
# Creator Attendance Portal — Environment Variables
# Copy this file to .env and fill in all values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Flask
FLASK_ENV=development          # Set to "production" on Render
SECRET_KEY=your-very-long-random-secret-key-here

# Google Sheets
# Paste the ENTIRE contents of your service account JSON key as a single line
# (use a JSON minifier or: python -c "import json,sys; print(json.dumps(json.load(open('key.json'))))")
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# Supabase (Authentication & Users)
SUPABASE_URL=your-supabase-project-url-here
SUPABASE_KEY=your-supabase-anon-key-here

# Optional: override attendance job time (UTC hours, default 13 = 18:30 IST)
# ATTENDANCE_JOB_HOUR_UTC=13
# ATTENDANCE_JOB_MINUTE_UTC=0

# SMTP Configuration for Email Notifications
SMTP_SERVER=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USERNAME=your-email@outlook.com
SMTP_PASSWORD=your-app-password-here
MANAGER_NOTIFICATION_EMAIL=your-manager-notification-email@example.com
